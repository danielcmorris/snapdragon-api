                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"YOUR_GOOGLE_ID_TOKEN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/google-login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "google-login"]
